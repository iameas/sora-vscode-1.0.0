{
    "scopeName": "source.sora",
    "patterns": [
        {
            "name": "keyword.control.sora",
            "match": "\\b(let|const|var|stay|if|else|elseif|for|while|show|make|is|not|can|be|math)\\b"
        },
        {
            "name": "string.quoted.double.sora",
            "begin": "\"",
            "end": "\""
        },
        {
            "name": "comment.line.sora",
            "match": "#.*"
        },
        {
            "name": "constant.numeric.sora",
            "match": "\\b\\d+(\\.\\d+)?\\b"
        }
    ]
}