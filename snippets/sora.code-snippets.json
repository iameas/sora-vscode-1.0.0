{
    "Print to Console": {
        "prefix": "show",
        "body": ["show(${1:message})"],
        "description": "Print a message to the console."
    },
    "If-Else Statement": {
        "prefix": "elseif",
        "body": [
            "if ${1:condition}:",
            "    ${2:# Code block for true condition}",
            "else:",
            "    ${3:# Code block for false condition}"
        ],
        "description": "Insert an else statement."
    },
    "Variable Declaration": {
        "prefix": "let",
        "body": ["let ${1:variableName} be (${2:value})"],
        "description": "Declare a variable in Sora."
    }
}